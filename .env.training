# Kaggle API ключі
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Hugging Face токен (вже є в системі)
HUGGINGFACE_TOKEN=your_hf_token

# Google API для збору додаткових даних
GOOGLE_API_KEY=your_google_api_key

# Конфігурація навчання
TRAINING_DATA_PATH=./datasets/architectural_styles
MODEL_SAVE_PATH=./models/archvision_kaggle
BATCH_SIZE=16
NUM_EPOCHS=30
LEARNING_RATE=1e-4